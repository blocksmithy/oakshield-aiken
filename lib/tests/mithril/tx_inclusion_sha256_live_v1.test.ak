// ── 6 accept tests, one per step ────────────────────────────────

test test_live_step_00_anchor_tx0_accept() {
  tx_inclusion_sha256.verify_inclusion(
    step_00_y_root, step_00_tx0_txid, #"", #"", 1, step_00_tx0_siblings(),
  )
}

test test_live_step_01_tx0_accept() {
  tx_inclusion_sha256.verify_inclusion(
    step_01_y_root, step_01_tx0_txid, #"", #"", 1, step_01_tx0_siblings(),
  )
}

