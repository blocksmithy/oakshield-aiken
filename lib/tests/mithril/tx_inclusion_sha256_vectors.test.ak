// ── v2 reject_wrong_block — block_number tampered to bn+1 ─────────

/// Same txid / slot / siblings as v2 first_tx, but block_number
/// incremented by 1 (`0x4a` → `0x4b`). Different leaf hash →
/// reconstructed root != Y → reject.
test adv_v2_wrong_block() {
  let tampered_block: ByteArray = #"4b420f0000000000"
  !tx_inclusion_sha256.verify_inclusion(
    v2_tree_y_root,
    v2_first_tx_txid,
    tampered_block,
    v2_first_tx_slot_le8,
    1,
    v2_first_tx_siblings(),
  )
}

// ── v2 reject_v1_leaf_on_v2 — using V1 dispatch on a v2 tree ──────

/// Caller submits a v2 tree's txid + siblings but asks the verifier
/// to hash the leaf as V1 (txid only, no block/slot). The leaf hash
/// differs from what the tree committed → reject.
test adv_v2_v1_leaf_does_not_satisfy() {
  !tx_inclusion_sha256.verify_inclusion(
    v2_tree_y_root,
    v2_first_tx_txid,
    #"",
    #"",
    1,
    v2_first_tx_siblings(),
  )
}

// ── IVC: same tx still proves against the extended Y1 ─────────────

/// Trail grows: Y0 (anchor) → Y1 (continuation with 3 added txids).
/// The original first_tx (leaf_index 1, same txid as v1) STILL
/// verifies against the new latest Y1 — extending the trail doesn't
/// invalidate prior leaves. Proves the IMT "append-only" property
/// is preserved through the IVC chain.
fn ivc_inclusion_siblings() -> List<ByteArray> {
  [
    #"63e2d11a161f9a1e24ed666b13effc760fd8d69413ad1e5b35ccf8aecefbb16b",
    #"951ca956801585ec4a615e89c361a69c90da683c661c308785688816ff606845",
    #"92ee34dc4b496988462708410476b815729a072d40cb827d73e438fc64d92d8c",
    #"8eba4c2ad5fa30a7c7d1d76c93da93140e5f23919154f1731ba0c76ce749241a",
    z(4),  z(5),  z(6),  z(7),
    z(8),  z(9),  z(10), z(11), z(12),
    z(13), z(14), z(15), z(16), z(17),
    z(18), z(19), z(20), z(21), z(22),
    z(23), z(24), z(25), z(26), z(27),
    z(28), z(29), z(30), z(31), z(32),
    z(33), z(34), z(35), z(36), z(37),
    z(38), z(39),
  ]
}

test test_ivc_inclusion_against_Y1() {
  tx_inclusion_sha256.verify_inclusion(
    ivc_y1_root,
    v1_first_tx_txid,
    #"",
    #"",
    1,
    ivc_inclusion_siblings(),
  )
}
