//// **Golden vectors from the upstream `oaks_txtree` team — phase 1.**
//// Source: `oaks_txtree_vectors_v1.tar.gz` delivered 2026-06-25,
//// generated by `oaks_txtree/runcheck/src/bin/gen_vectors.rs` — the
//// same code path the guest commits with. Every accept/reject
//// expectation was self-checked by the generator's `imt_verify`.
////
//// These tests are the regression suite: our on-chain
//// `verify_inclusion` must accept exactly what upstream accepts and
//// reject exactly what upstream rejects. A drift here means our
//// Aiken port has diverged from the reference Rust verifier.
////
//// Covered (upstream tarball file → test):
////   - `v1/inclusion/first_tx.json`        → test_v1_first_tx_accept
////   - `v1/inclusion/last_tx.json`         → test_v1_last_tx_accept
////   - `v1/reject_tamper.json`             → adv_v1_tampered_sibling_byte
////   - `v2/inclusion/first_tx.json`        → test_v2_first_tx_accept
////   - `v2/inclusion/last_tx.json`         → test_v2_last_tx_accept
////   - `v2/reject_wrong_block.json`        → adv_v2_wrong_block
////   - `v2/reject_v1_leaf_on_v2.json`      → adv_v2_v1_leaf_does_not_satisfy
////   - `ivc/inclusion_vs_Y1.json`          → test_ivc_inclusion_against_Y1
////
//// The `zeros` table is pinned against upstream in
//// `tx_inclusion_sha256.test.ak::test_zeros_40_matches_upstream_reference_value`.

use aiken/collection/list
use mithril/tx_inclusion_sha256

/// Resolve `zeros[k]` from the module's pinned zero-subtree table.
fn z(k: Int) -> ByteArray {
  expect Some(v) = list.at(tx_inclusion_sha256.zeros, k)
  v
}

// ── Trees (shared across multiple proofs) ─────────────────────────

const v1_tree_y_root: ByteArray =
  #"20f132941e9e82be45faba937dd4e9d9c5933c805ff2dcb14d51618c11aafb34"

const v2_tree_y_root: ByteArray =
  #"87bb90506b95fbf2c9053692ddae6ebc987f6ea7eb140fcb1c51e49bd50fdf40"

const ivc_y1_root: ByteArray =
  #"21a0ef91d6df2367132a4b8469dab4c7ab130a3a77f7d13c7103ff775d2ffdfd"

// ── v1 first_tx (accept) ──────────────────────────────────────────

const v1_first_tx_txid: ByteArray =
  #"c1055f5a01fd30cf1a7fd249af4aedf189b8ef370562f1f9868bbd3da17c5ec8"

fn v1_first_tx_siblings() -> List<ByteArray> {
  [
    #"63e2d11a161f9a1e24ed666b13effc760fd8d69413ad1e5b35ccf8aecefbb16b",
    #"951ca956801585ec4a615e89c361a69c90da683c661c308785688816ff606845",
    #"92ee34dc4b496988462708410476b815729a072d40cb827d73e438fc64d92d8c",
    z(3),  z(4),  z(5),  z(6),  z(7),
    z(8),  z(9),  z(10), z(11), z(12),
    z(13), z(14), z(15), z(16), z(17),
    z(18), z(19), z(20), z(21), z(22),
    z(23), z(24), z(25), z(26), z(27),
    z(28), z(29), z(30), z(31), z(32),
    z(33), z(34), z(35), z(36), z(37),
    z(38), z(39),
  ]
}

test test_v1_first_tx_accept() {
  tx_inclusion_sha256.verify_inclusion(
    v1_tree_y_root,
    v1_first_tx_txid,
    #"",
    #"",
    1,
    v1_first_tx_siblings(),
  )
}

