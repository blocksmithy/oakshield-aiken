const v2_last_tx_txid: ByteArray =
  #"e1b49e5d36a2455b5ff21a4b57a5a99e759d3ab10664f6904d5c5452918d8538"

const v2_last_tx_block_le8: ByteArray = #"4d420f0000000000"

