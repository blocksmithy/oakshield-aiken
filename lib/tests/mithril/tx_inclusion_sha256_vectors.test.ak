// ── v1 reject_tamper — sibling byte flipped 0x63 → 0x62 ────────────

/// Same v1 first_tx proof, but sibling[0] first byte tampered from
/// `0x63` (genuine) to `0x62`. The reconstructed root becomes
/// `c0481a77…`, NOT the genuine Y; verify_inclusion returns False.
fn v1_tamper_siblings() -> List<ByteArray> {
  [
    #"62e2d11a161f9a1e24ed666b13effc760fd8d69413ad1e5b35ccf8aecefbb16b",
    #"951ca956801585ec4a615e89c361a69c90da683c661c308785688816ff606845",
    #"92ee34dc4b496988462708410476b815729a072d40cb827d73e438fc64d92d8c",
    z(3),  z(4),  z(5),  z(6),  z(7),
    z(8),  z(9),  z(10), z(11), z(12),
    z(13), z(14), z(15), z(16), z(17),
    z(18), z(19), z(20), z(21), z(22),
    z(23), z(24), z(25), z(26), z(27),
    z(28), z(29), z(30), z(31), z(32),
    z(33), z(34), z(35), z(36), z(37),
    z(38), z(39),
  ]
}

test adv_v1_tampered_sibling_byte() {
  !tx_inclusion_sha256.verify_inclusion(
    v1_tree_y_root,
    v1_first_tx_txid,
    #"",
    #"",
    1,
    v1_tamper_siblings(),
  )
}

// ── v2 first_tx (accept) — block-bound leaf ───────────────────────

const v2_first_tx_txid: ByteArray =
  #"8b5862bac8e4691359f54a7139818ec033ffc5bafda3eb52e516be53b08eda18"

const v2_first_tx_block_le8: ByteArray = #"4a420f0000000000"

const v2_first_tx_slot_le8: ByteArray = #"8af0fa0200000000"

fn v2_first_tx_siblings() -> List<ByteArray> {
  [
    #"63e2d11a161f9a1e24ed666b13effc760fd8d69413ad1e5b35ccf8aecefbb16b",
    #"46332e3e413d976d9349de26c46492d159a0c24e9e4795c6c68285ca6cfae56e",
    #"a6ae484dce95a8c5600bf4edccf839054c6349a21ec0f4f88db1f977da84f700",
    z(3),  z(4),  z(5),  z(6),  z(7),
    z(8),  z(9),  z(10), z(11), z(12),
    z(13), z(14), z(15), z(16), z(17),
    z(18), z(19), z(20), z(21), z(22),
    z(23), z(24), z(25), z(26), z(27),
    z(28), z(29), z(30), z(31), z(32),
    z(33), z(34), z(35), z(36), z(37),
    z(38), z(39),
  ]
}

test test_v2_first_tx_accept() {
  tx_inclusion_sha256.verify_inclusion(
    v2_tree_y_root,
    v2_first_tx_txid,
    v2_first_tx_block_le8,
    v2_first_tx_slot_le8,
    1,
    v2_first_tx_siblings(),
  )
}

